// tsconfig specifically for the Cloudflare Worker, which targets a different
// environment (no DOM, uses workers-types instead).
{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@content/*": ["../content/*"]
    }
  },
  "include": ["index.ts", "../content"]
}
