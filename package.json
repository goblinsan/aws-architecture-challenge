{
  "name": "aws-architecture-challenge",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "vite build",
    "preview": "wrangler dev --local",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "nanoid": "5",
    "react": "18",
    "react-dom": "18"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4",
    "@types/react": "18",
    "@types/react-dom": "18",
    "@typescript-eslint/eslint-plugin": "6",
    "@typescript-eslint/parser": "6",
    "@vitejs/plugin-react": "4",
    "autoprefixer": "10",
    "eslint": "8",
    "postcss": "8",
    "prettier": "3",
    "tailwindcss": "3",
    "typescript": "5",
    "vite": "5",
    "wrangler": "3"
  }
}
